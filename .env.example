# Produção (Render): obrigatório. Local: opcional se PostgreSQL estiver em localhost:5432/postgres.
DATABASE_URL=
# Alternativa só para desenvolvimento (não usar no Render).
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Chave única para Geocoding, Distance Matrix e Maps JS na Central (opcional).
GOOGLE_MAPS_API_KEY=sua_chave_google_aqui
