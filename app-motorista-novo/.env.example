# Expo LAN — IP Wi-Fi local
#
# Problema conhecido: adaptador "Topaz Loopback" (Cursor IDE) com IP 54.232.x
# e mascara 0.0.0.0 faz o Expo detectar IP errado no QR Code.
# REACT_NATIVE_PACKAGER_HOSTNAME abaixo corrige isso.
#
EXPO_PUBLIC_API_BASE=http://192.168.0.97:8000
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.97
