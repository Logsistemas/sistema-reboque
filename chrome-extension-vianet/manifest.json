{
  "manifest_version": 3,
  "name": "Essência Exportador",
  "version": "1.3.0",
  "description": "Importa serviços do Vianet/Mondial para o Sistema Essência Logística",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://vianet.webmondial.com.br/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Essência Exportador"
  },
  "content_scripts": [
    {
      "matches": ["https://vianet.webmondial.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
